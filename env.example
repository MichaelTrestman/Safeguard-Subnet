# Network configuration
NETWORK=local
NETUID=2

# Wallet configuration
WALLET_NAME=validator
HOTKEY_NAME=default

# Logging
LOG_LEVEL=INFO

# Chutes API (required — used by miner for attacks + scoring, validator for tier 2/3)
CHUTES_API_KEY=
CHUTES_MODEL_TIER2=deepseek-ai/DeepSeek-V3-0324
CHUTES_MODEL_TIER3=deepseek-ai/DeepSeek-V3-0324

# Target configuration
# Single target (backward compatible):
TARGET_VALIDATOR_ENDPOINT=http://localhost:9000
# Multi-target (overrides single target if set):
# TARGET_CONFIGS_FILE=target_configs.json

# Cross-subnet API
API_HOST=0.0.0.0
API_PORT=9090

# HITL API
HITL_HOST=0.0.0.0
HITL_PORT=9091
